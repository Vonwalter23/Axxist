# Axxist Release Keystore Configuration
# Copy this file to keystore.properties and fill in your values
# DO NOT commit keystore.properties to version control

# ===========================================
# DEBUG SIGNING (Optional overrides)
# ===========================================
DEBUG_STORE_PASSWORD=android
DEBUG_KEY_ALIAS=androiddebugkey
DEBUG_KEY_PASSWORD=android

# ===========================================
# RELEASE SIGNING (Required for production)
# ===========================================
# Path to your release keystore file (relative to android/ or absolute)
RELEASE_KEYSTORE_PATH=release.keystore

# Keystore password
RELEASE_STORE_PASSWORD=your_keystore_password_here

# Key alias
RELEASE_KEY_ALIAS=your_key_alias_here

# Key password
RELEASE_KEY_PASSWORD=your_key_password_here
