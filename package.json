{
  "name": "axxist",
  "version": "0.0.1-foundation",
  "description": "Intelligent Assistant for Android - Plataforma de asistencia inteligente",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format": "npm run lint:fix && npm run prettier",
    "build:android": "cd android && ./gradlew assembleDebug",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vonwalter23/Axxist.git"
  },
  "keywords": [
    "assistant",
    "android",
    "voice",
    "ai",
    "react-native",
    "kotlin"
  ],
  "author": "Vonwalter23",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Vonwalter23/Axxist/issues"
  },
  "homepage": "https://github.com/Vonwalter23/Axxist#readme",
  "dependencies": {
    "react": "^18.3.1",
    "react-native": "^0.76.6"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.4",
    "@babel/core": "^8.0.1",
    "@babel/runtime": "^8.0.0",
    "@react-native-community/cli-platform-android": "^15.1.3",
    "@react-native/babel-preset": "^0.86.0",
    "@react-native/eslint-config": "^0.86.0",
    "@types/react": "^19.2.17",
    "@types/react-native": "^0.72.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "metro": "^0.87.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.9.5",
    "react-native-gradle-plugin": "^0.71.19",
    "typescript": "5.3"
  }
}
